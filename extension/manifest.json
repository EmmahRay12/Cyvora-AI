{
  "manifest_version": 3,
  "name": "Cyvora AI",
  "description": "AI-powered browser privacy and security extension.",
  "version": "0.1.0",

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Cyvora AI"
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/warningOverlay.js",
        "content/detector.js",
        "content/loginAnalyzer.js"
      ],
      "run_at": "document_end"
    }
  ]
}